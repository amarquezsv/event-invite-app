# Frontend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# Base URL of your Azure Function App (no trailing slash).
# For local dev run `func start` in the backend folder.
VITE_API_URL=http://localhost:7071/api

# Admin panel secret key — protects the /admin/* routes.
# Set a strong random string here. Leave blank to skip auth in dev.
VITE_ADMIN_KEY=change-me-in-production

